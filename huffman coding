import heapq

def huffman(chars, freq):
    heap = [[f,[c,""]] for c,f in zip(chars,freq)]
    heapq.heapify(heap)
    
    while len(heap)>1:
        l = heapq.heappop(heap)
        r = heapq.heappop(heap)
        
        for pair in l[1:]:
            pair[1] = '0' + pair[1]
        for pair in r[1:]:
            pair[1] = '1' + pair[1]
            
        heapq.heappush(heap,[l[0]+r[0]] + l[1:] + r[1:])
        
    return sorted(heap[0][1:])

print(huffman(['a','b','c','d'],[5,9,12,13]))
